{
    "name": "@runeauth/sdk",
    "version": "2.2.1",
    "description": "Rune Authorization SDK — zero-dependency Node.js client for relationship-based access control",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "pnpm typecheck && pnpm build"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "authorization",
        "rebac",
        "permissions",
        "access-control",
        "rune",
        "iam"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/praveenraj-sk/Rune.git"
    },
    "homepage": "https://github.com/praveenraj-sk/Rune#readme",
    "bugs": {
        "url": "https://github.com/praveenraj-sk/Rune/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
