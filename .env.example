# ─── Server ────────────────────────────────────────────────────────────────
PORT=4078
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────
# Matches docker-compose.yml — Postgres on port 5433 to avoid conflicts
DATABASE_URL=postgresql://rune:runepassword@localhost:5433/runedb
DB_POOL_MAX=10
DB_POOL_MIN=2

# ─── Cache ──────────────────────────────────────────────────────────────────
MAX_CACHE_SIZE=10000

# ─── BFS Safety Limits ─────────────────────────────────────────────────────
# Increase only if you have deep org hierarchies (>20 levels)
MAX_BFS_DEPTH=20
MAX_BFS_NODES=1000

# ─── Security ───────────────────────────────────────────────────────────────
# Must be at least 32 characters — change before any real deployment
# Generate one: openssl rand -base64 32
API_KEY_SALT=change_this_to_a_random_32_char_string_minimum

# ─── SDK / Client ────────────────────────────────────────────────────────────
# Paste your API key here after running: pnpm run setup
RUNE_API_KEY=
RUNE_URL=http://localhost:4078
